Private Const COL_AGENT As Long = 1
Private Const COL_CONTACT_A As Long = 2
Private Const COL_CONTACT_B As Long = 3
Private Const COL_PID As Long = 4
Private Const COL_REF As Long = 5

Private ws As Worksheet

Sub Initialize()
    Set ws = ThisWorkbook.Sheets("Sheet1")
End Sub

Sub SuspiciousDataDetection()

Dim startTime As Double
startTime = Timer

' Initialize dictionaries for tracking
Dim suspiciousPatterns As Object, agentAbuse As Object, eSignAbuse As Object
Set suspiciousPatterns = CreateObject("Scripting.Dictionary")
Set agentAbuse = CreateObject("Scripting.Dictionary")
Set eSignAbuse = CreateObject("Scripting.Dictionary")

Dim row As Long, agentID As String, personalData As String, eSignature As String

' Pre-fetch the range to minimize calls to the worksheet
Dim dataRange As Variant
dataRange = ws.Range(ws.Cells(2, 1), ws.Cells(100000, COL_PID)).Value

For row = 1 To UBound(dataRange, 1)
    agentID = dataRange(row, COL_AGENT - 1) ' Adjusted for 0-based array
    personalData = dataRange(row, COL_CONTACT_A - 1) & dataRange(row, COL_CONTACT_B - 1) & dataRange(row, COL_PID - 1)
    eSignature = dataRange(row, COL_REF - 1) ' Adjusted for 0-based array
    
    ' Check for personal data abuse
    If Not suspiciousPatterns.Exists(personalData) Then
        suspiciousPatterns.Add personalData, agentID
    ElseIf suspiciousPatterns(personalData) <> agentID Then
        agentAbuse(personalData) = agentAbuse(personalData) + 1
    End If
    
    ' Check for electronic signature abuse
    eSignAbuse(eSignature) = eSignAbuse(eSignature) + 1
Next row

' Output results
Dim key As Variant
For Each key In agentAbuse
    If agentAbuse(key) > 2 Then
        MsgBox "Potential abuse detected with personal data: " & key
    End If
Next key

For Each key In eSignAbuse
    If eSignAbuse(key) > 1 Then
        MsgBox "Potential abuse detected with electronic signatures: " & key
    End If
Next key

Dim endTime As Double
endTime = Timer
MsgBox "Process completed in " & endTime - startTime & " seconds."

End Sub

