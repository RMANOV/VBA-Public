Sub AnalyzeAgentInteractions()
    ' Setup worksheet and determine the last row of data
    Dim ws As Worksheet
    Set ws = ThisWorkbook.Sheets(1)
    Dim lastRow As Long
    lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row
    
    ' Dictionary to hold each agent and their connections
    Dim interactions As Object
    Set interactions = CreateObject("Scripting.Dictionary")
    
    ' Populate the dictionary with data from the worksheet
    Dim i As Long
    For i = 2 To lastRow ' Assuming the first row is the header
        Dim agent1 As String
        Dim location1 As String
        agent1 = ws.Cells(i, 11).Value
        location1 = ws.Cells(i, 15).Value

        ' Add interaction for the first agent
        If Not interactions.Exists(agent1) Then
            Set interactions(agent1) = CreateObject("Scripting.Dictionary")
        End If
        ' interactions(agent1).Add location1, Nothing
        If interactions(agent1).Exists(location1) Then
            interactions(agent1)(location1) = interactions(agent1)(location1) + 1
        Else
            interactions(agent1)(location1) = 1
        End If

        ' Optionally add reverse interaction for bidirectional relationships
        If Not interactions.Exists(location1) Then
            Set interactions(location1) = CreateObject("Scripting.Dictionary")
        End If
        If interactions(location1).Exists(agent1) Then
            interactions(location1)(agent1) = interactions(location1)(agent1) + 1
        Else
            interactions(location1)(agent1) = 1
        End If
    Next i

    ' Analyze the network to find agents with unusually high number of connections
    Dim key As Variant, connectedAgents As Variant
    Dim flaggedAgents As Object
    Set flaggedAgents = CreateObject("Scripting.Dictionary")

    For Each key In interactions.Keys
        Set connectedAgents = interactions(key)
        ' Example criterion: flag agents with more than 5 connections
        If connectedAgents.Count > 2 Then
            flaggedAgents.Add key, connectedAgents
        End If
    Next key

    ' Output the flagged agents and their connections
    Dim outputWs As Worksheet
    ' Create a new worksheet to output the results after current worksheet
    Set outputWs = ThisWorkbook.Sheets.Add(After:=ws)
    outputWs.Name = "Flagged Agents"

    Dim outputRow As Long
    outputRow = 1
    outputWs.Cells(outputRow, 1).Value = "Agent ID"
    outputWs.Cells(outputRow, 2).Value = "Number of connections"

    For Each key In flaggedAgents.Keys
        outputRow = outputRow + 1
        outputWs.Cells(outputRow, 1).Value = key
        outputWs.Cells(outputRow, 2).Value = flaggedAgents(key).Count
    Next key

    for each key in flaggedAgents.Keys
        outputRow = outputRow + 1
        outputWs.Cells(outputRow, 1).Value = key
        outputWs.Cells(outputRow, 2).Value = "Connected to:"
        outputRow = outputRow + 1
        for each connectedAgent in flaggedAgents(key).Keys
            outputWs.Cells(outputRow, 1).Value = connectedAgent
            outputWs.Cells(outputRow, 2).Value = flaggedAgents(key)(connectedAgent)
            outputRow = outputRow + 1
        next connectedAgent

    next key





    ' Output message to indicate completion
    MsgBox "Analysis complete."
End Sub
