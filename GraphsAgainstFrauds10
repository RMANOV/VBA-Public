Private Sub AnalyzeAgentInteractionNetwork(ByRef suspiciousData As Variant)
    Dim agentConnections As Object
    Set agentConnections = CreateObject("Scripting.Dictionary")

    Dim i As Long
    For i = 1 To UBound(suspiciousData, 1)
        Dim agent As String: agent = suspiciousData(i, 3)
        Dim location As String: location = suspiciousData(i, 5)
        Dim entity1 As String: entity1 = suspiciousData(i, 6)
        Dim entity2 As String: entity2 = suspiciousData(i, 7)
        Dim entity3 As String: entity3 = suspiciousData(i, 8)

        If Not agentConnections.Exists(agent) Then
            Set agentConnections(agent) = CreateObject("Scripting.Dictionary")
        End If

        If Not agentConnections(agent).Exists(location) Then
            agentConnections(agent).Add location, New Collection
        End If

        agentConnections(agent)(location).Add entity1, Nothing, Nothing, True
        agentConnections(agent)(location).Add entity2, Nothing, Nothing, True
        agentConnections(agent)(location).Add entity3, Nothing, Nothing, True
    Next i

    Dim networkSheet As Worksheet
    Set networkSheet = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
    networkSheet.Name = "Interaction Network"

    Dim nodeRow As Long: nodeRow = 1
    For Each agt In agentConnections
        networkSheet.Cells(nodeRow, 1).Value = agt
        nodeRow = nodeRow + 1
    Next agt

    Dim edgeRow As Long: edgeRow = 1
    For Each agt In agentConnections
        Dim loc As Variant
        For Each loc In agentConnections(agt)
            Dim ent As Variant
            For Each ent In agentConnections(agt)(loc)
                networkSheet.Cells(edgeRow, 2).Value = agt
                networkSheet.Cells(edgeRow, 3).Value = loc
                networkSheet.Cells(edgeRow, 4).Value = ent
                edgeRow = edgeRow + 1
            Next ent
        Next loc
    Next agt

    networkSheet.Columns("A:D").AutoFit
    networkSheet.Range("A1:D1").Font.Bold = True

    AnalyzeNetworkGraph networkSheet
End Sub

Private Sub AnalyzeNetworkGraph(ByRef networkSheet As Worksheet)
    Dim agentConnections As Object
    Set agentConnections = CreateObject("Scripting.Dictionary")

    Dim row As Long
    For row = 2 To networkSheet.Cells(Rows.Count, 1).End(xlUp).Row
        Dim agent As String: agent = networkSheet.Cells(row, 2).Value
        If Not agentConnections.Exists(agent) Then
            agentConnections(agent) = 1
        Else
            agentConnections(agent) = agentConnections(agent) + 1
        End If
    Next row

    Dim hub As Variant
    For Each hub In agentConnections
        If agentConnections(hub) > Application.WorksheetFunction.Median(agentConnections.Items) * 2 Then
            MsgBox "Potential hub detected: " & hub & " has " & agentConnections(hub) & " connections."
        End If
    Next hub

