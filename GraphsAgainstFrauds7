Const COL_CONTACT_A As Long = 13
Const COL_CONTACT_B As Long = 12
Const COL_REF As Long = 1
Const COL_TIMESTAMP As Long = 2
Const COL_LOCATION As Long = 15
Const COL_ENTITY1 As Long = 4
Const COL_ENTITY2 As Long = 5
Const COL_ENTITY3 As Long = 6
Const COL_PID As Long = 3
Const COL_AGENT As Long = 11

Sub IdentifySuspiciousData()
    Application.ScreenUpdating = False
    Application.Calculation = xlCalculationManual
    Application.EnableEvents = False

    Dim ws As Worksheet
    Set ws = ThisWorkbook.Sheets(1)
    Dim lastRow As Long
    lastRow = ws.Cells(ws.Rows.Count, "A").End(xlUp).Row

    Dim dataRange As Range
    Set dataRange = ws.Range("A2:AR" & lastRow)
    Dim data As Variant
    data = dataRange.Value

    Dim contactDict As Object
    Set contactDict = CreateObject("Scripting.Dictionary")

    Dim i As Long
    For i = 1 To UBound(data, 1)
        Dim contactKey As String
        contactKey = data(i, COL_CONTACT_A) & "|" & data(i, COL_CONTACT_B)
        If Not contactDict.Exists(contactKey) Then
            contactDict.Add contactKey, New Collection
        End If
        contactDict(contactKey).Add i
    Next i

    Dim suspiciousData As Variant
    ReDim suspiciousData(1 To 0, 1 To 9)

    Dim suspiciousRowCount As Long
    suspiciousRowCount = 0

    Dim key As Variant
    For Each key In contactDict
        If contactDict(key).Count >= 3 Then
            Dim agents As Object, locations As Object
            Set agents = CreateObject("Scripting.Dictionary")
            Set locations = CreateObject("Scripting.Dictionary")

            Dim idx As Variant
            For Each idx In contactDict(key)
                Dim agentKey As String
                agentKey = CStr(data(idx, COL_AGENT))
                Dim locationKey As String
                locationKey = CStr(data(idx, COL_LOCATION))
                If Not agents.Exists(agentKey) Then
                    agents.Add agentKey, Nothing
                End If
                If Not locations.Exists(locationKey) Then
                    locations.Add locationKey, Nothing
                End If
            Next idx

            If agents.Count > 2 Or locations.Count > 2 Then
                For Each idx In contactDict(key)
                    suspiciousRowCount = suspiciousRowCount + 1
                    ReDim Preserve suspiciousData(1 To suspiciousRowCount, 1 To 9)
                    suspiciousData(suspiciousRowCount, 1) = data(idx, COL_REF)
                    suspiciousData(suspiciousRowCount, 2) = data(idx, COL_TIMESTAMP)
                    suspiciousData(suspiciousRowCount, 3) = data(idx, COL_AGENT)
                    suspiciousData(suspiciousRowCount, 4) = key
                    suspiciousData(suspiciousRowCount, 5) = data(idx, COL_LOCATION)
                    suspiciousData(suspiciousRowCount, 6) = data(idx, COL_ENTITY1)
                    suspiciousData(suspiciousRowCount, 7) = data(idx, COL_ENTITY2)
                    suspiciousData(suspiciousRowCount, 8) = data(idx, COL_ENTITY3)
                    suspiciousData(suspiciousRowCount, 9) = data(idx, COL_PID)
                Next idx
            End If
        End If
    Next key

    If suspiciousRowCount > 0 Then
        Dim exportSheet As Worksheet
        Set exportSheet = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
        exportSheet.Range("A1:I1").Value = Array("ID", "Date", "Agent", "Contact Info", "Location", "Entity 1", "Entity 2", "Entity 3", "PID")
        exportSheet.Range("A2").Resize(suspiciousRowCount, 9).Value = suspiciousData
        exportSheet.Cells.NumberFormat = "@" ' Format as text
        exportSheet.Columns("A:I").AutoFit ' Auto-fit columns
    End If

    AnalyzeSuspiciousGraph suspiciousData
    CheckAgentMultipleLocations suspiciousData

    Application.ScreenUpdating = True
    Application.Calculation = xlCalculationAutomatic
    Application.EnableEvents = True

    MsgBox "Data processed and exported."
End Sub

Private Sub AnalyzeSuspiciousGraph(ByRef suspiciousData As Variant)
    Dim graph As Object
    Set graph = CreateObject("Scripting.Dictionary")

    Dim i As Long
    For i = 1 To UBound(suspiciousData, 1)
        Dim agent As String: agent = suspiciousData(i, 3)
        Dim location As String: location = suspiciousData(i, 5)
        Dim contactInfo As String: contactInfo = suspiciousData(i, 4) ' Key for contact info

        If Not graph.Exists(contactInfo) Then
            Set graph(contactInfo) = CreateObject("Scripting.Dictionary")
        End If

        If Not graph(contactInfo).Exists(agent) Then
            graph(contactInfo).Add agent, location
        Else
            ' If the agent already exists under this contact info, check for different location
            If graph(contactInfo)(agent) <> location Then
                ' This indicates a potential abuse scenario where the same agent is associated with different locations under the same contact info
                MsgBox "Potential abuse detected for " & agent & " under contact info " & contactInfo & ". Different locations found: " & graph(contactInfo)(agent) & " and " & location
            End If
        End If
    Next i

    ' Further analysis can be done here, such as identifying specific subgraphs indicating abuse
    ' For example, if multiple agents are associated with the same contact info and different locations, it could indicate a pattern of abuse
    ' This would require more complex graph analysis algorithms

    MsgBox "Graph analysis completed."
End Sub

Private Sub CheckAgentMultipleLocations(ByRef suspiciousData As Variant)
    Dim agentLocations As Object
    Set agentLocations = CreateObject("Scripting.Dictionary")

    Dim i As Long
    For i = 1 To UBound(suspiciousData, 1)
        Dim agent As String: agent = suspiciousData(i, 3)
        Dim location As String: location = suspiciousData(i, 5)
        Dim date As Date: date = CDate(suspiciousData(i, 2))

        If Not agentLocations.Exists(agent) Then
            Set agentLocations(agent) = CreateObject("Scripting.Dictionary")
        End If

        If Not agentLocations(agent).Exists(date) Then
            agentLocations(agent).Add date, New Collection
        End If

        agentLocations(agent)(date).Add location, Nothing, Nothing, True ' Use a dictionary to ensure uniqueness
    Next i

    Dim agt As Variant
    For Each agt In agentLocations
        Dim dt As Variant
        For Each dt In agentLocations(agt)
            If agentLocations(agt)(dt).Count > 1 Then
                MsgBox "Agent " & agt & " registered in multiple locations on " & Format(dt, "dd.mm.yyyy") & ": " & Join(CollectionToArray(agentLocations(agt)(dt)), ", ")
            End If
        Next dt
    Next agt
End Sub

Private Function CollectionToArray(ByRef coll As Collection) As Variant
    Dim arr() As Variant
    ReDim arr(1 To coll.Count)
    Dim i As Long
    For i = 1 To coll.Count
        arr(i) = coll(i)
    Next i
    CollectionToArray = arr
End Function
